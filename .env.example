# Copy to .env and fill in real secrets before `docker compose up`.

# --- Postgres (used by the postgres service + all 3 binaries) ---
POSTGRES_USER=sf
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sf_clone

# --- JWT shared secret with Laravel (must match the signing side) ---
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-48-byte-random-string

# --- API exposure ---
# The port the EC2 host exposes. Front this with Nginx/ALB for TLS.
API_PORT=3000

# --- Runtime ---
RUST_LOG=info

# --- Dev only: set to 1 to mint a bypass token. NEVER set on prod. ---
SF_DEV_MODE=
