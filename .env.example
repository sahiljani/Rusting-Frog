# Copy to .env (for local dev) or /opt/sf-clone/.env (on the EC2 host
# used by docker-compose.prod.yml) and fill in real values.

# --- Postgres (used by the postgres service + all 3 binaries) ---
POSTGRES_USER=sf
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sf_clone

# --- JWT shared secret with Laravel (must match the signing side) ---
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-48-byte-random-string

# --- API exposure ---
# The port the EC2 host exposes. Front this with Nginx/ALB for TLS.
# In prod the api service is NOT published directly — the `ui` nginx
# container proxies /v1/* on port 80. This is retained for dev/compose.
API_PORT=3000

# --- UI (nginx + React SPA) ---
# The port the EC2 host exposes for the frontend. Front with ALB/TLS
# in a real deployment.
UI_PORT=80

# --- Runtime ---
RUST_LOG=info

# --- Dev only: set to 1 to mint a bypass token. NEVER set on prod. ---
SF_DEV_MODE=

# --- Production only (docker-compose.prod.yml + /opt/sf-clone/deploy.sh) ---
# Values come from `aws ecr describe-repositories`.
#   IMAGE_REGISTRY = <account>.dkr.ecr.<region>.amazonaws.com
#   IMAGE_REPO     = sf-clone  (whatever you named the ECR repo)
# AWS_REGION is consumed by deploy.sh when it calls `aws ecr get-login-password`.
IMAGE_REGISTRY=
IMAGE_REPO=sf-clone
IMAGE_REPO_UI=sf-clone-ui
AWS_REGION=us-east-1
