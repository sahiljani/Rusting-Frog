  "query": "\n        SELECT u.url, u.status_code, u.title, u.title_length\n        FROM crawl_urls u\n        JOIN crawl_url_findings f ON f.crawl_url_id = u.id\n        WHERE u.crawl_id = $1 AND f.filter_key = $2\n        ORDER BY u.url\n        LIMIT $3\n        ",
