  "query": "\n        SELECT url, title, title_length, title_pixel_width,\n               meta_description, meta_description_length\n        FROM crawl_urls\n        WHERE crawl_id = $1\n          AND is_internal = true\n          AND content_type = 'html'\n          AND status_code BETWEEN 200 AND 299\n        ORDER BY url\n        LIMIT $2\n        ",
