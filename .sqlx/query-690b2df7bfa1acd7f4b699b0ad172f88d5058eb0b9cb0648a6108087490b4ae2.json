{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id, u.url, u.status_code, u.content_type,\n               u.content_length, u.response_time_ms, l.anchor_text\n        FROM crawl_links l\n        JOIN crawl_urls u ON u.id = l.target_url_id\n        WHERE l.source_url_id = $1\n          AND l.crawl_id = $2\n          AND u.content_type = 'image'\n        ORDER BY u.url\n        ",
